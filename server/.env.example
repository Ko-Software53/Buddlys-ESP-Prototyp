# --- Mistral credentials ---
MISTRAL_API_KEY="NWGzc8WkeAuui2KD1ZGpQ1q1B32JQXk3"

# --- Chat model ---
# Default chat model. Override hier mit deinem finetuned Modell, sobald du eines hast,
# z. B. MISTRAL_MODEL=ft:mistral-small-2506:your-org:buddly:abcd1234
MISTRAL_MODEL=mistral-small-2506

# --- TTS: Cartesia Sonic (Streaming-WebSocket, ~75 ms TTFB) ---
# Account anlegen: https://play.cartesia.ai/  → Dashboard → API Keys
CARTESIA_API_KEY=sk_car_fwcH6DVbBWxDpH8F92Um63

# Voice klonen unter https://play.cartesia.ai/voices :
#   1) "Clone Voice" → 10–30 s Audio hochladen
#   2) Voice öffnen → ID kopieren (UUID-Format)
CARTESIA_VOICE_ID=7f88148a-347b-4fbc-954a-018117844e06

# Modell. sonic-3 = schnellstes aktuelles Modell.
CARTESIA_MODEL=sonic-3
CARTESIA_LANGUAGE=de

# --- Web-Search (Tavily, optional aber empfohlen) ---
# Account: https://tavily.com  → Dashboard → API Keys (free: 1000 calls/Monat)
TAVILY_API_KEY=

# --- (optional, nicht aktiv) Mistral Voxtral TTS Reste ---
MISTRAL_TTS_MODEL=voxtral-mini-tts-2603
MISTRAL_TTS_VOICE=
MISTRAL_TTS_FORMAT=wav

# --- STT (Speech-to-Text) ---
MISTRAL_STT_MODEL=voxtral-mini-2507
MISTRAL_STT_LANGUAGE=de

# Server-Port
PORT=3001
